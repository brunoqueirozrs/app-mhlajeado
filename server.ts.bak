app.get("/api/admin/env", (req, res) => {
  const safeEnv: Record<string, string> = {};
  for (const k in process.env) {
    const val = process.env[k];
    if (val && val.length > 8) {
       safeEnv[k] = val.substring(0, 4) + '...' + val.substring(val.length - 4);
    } else if (val) {
       safeEnv[k] = '***';
    } else {
       safeEnv[k] = '';
    }
  }
  res.json({ env: safeEnv });
});
